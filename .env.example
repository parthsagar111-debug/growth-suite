# Supabase (memory layer)
SUPABASE_URL=
SUPABASE_KEY=

# n8n webhook URLs — one per tool. Leave blank to run the app in demo
# mode (bundled sample data, no live calls, no cost).
N8N_WEBHOOK_FUNNEL=
N8N_WEBHOOK_LIFECYCLE=
N8N_WEBHOOK_EXPERIMENT=
N8N_WEBHOOK_RESULTS=

# Used only if Supabase isn't configured yet — lets you flip the
# frontend kill switch locally without a database.
GROWTH_SUITE_LIVE=true

# Used by the n8n workflows themselves (set these in n8n, not here)
# PDFCO_API_KEY=

# Used directly by First Response (Streamlit calls Groq itself — no n8n
# workflow for this tool). Leave blank to disable live diagnostic chat;
# the "Try the demo" walkthrough still works without it (fully scripted,
# no AI call).
GROQ_API_KEY=
