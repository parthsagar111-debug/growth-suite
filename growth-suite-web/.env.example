# Supabase (memory layer) — optional, falls back to bundled demo data
SUPABASE_URL=
SUPABASE_KEY=

# n8n webhook URLs — one per tool. Leave blank to run in demo mode.
N8N_WEBHOOK_FUNNEL=
N8N_WEBHOOK_LIFECYCLE=
N8N_WEBHOOK_EXPERIMENT=
N8N_WEBHOOK_RESULTS=

# Used only if Supabase isn't configured — lets you flip the kill switch
# locally without a database.
GROWTH_SUITE_LIVE=true

# First Response's scripted "Try the demo" walkthrough needs no API key
# at all. This is only for a future live diagnostic chat mode.
GROQ_API_KEY=
